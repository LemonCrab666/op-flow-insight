#!/bin/sh /etc/rc.common

USE_PROCD=1
START=99
STOP=10

start_service() {
	config_load op-flow
	local enabled
	config_get_bool enabled main enabled 1
	[ "$enabled" -eq 1 ] || return 0

	# Conntrack accounting applies to newly created entries. The daemon exposes
	# a clear health warning until byte counters become available.
	[ -w /proc/sys/net/netfilter/nf_conntrack_acct ] &&
		echo 1 > /proc/sys/net/netfilter/nf_conntrack_acct

	mkdir -p /etc/op-flow /usr/share/op-flow/data /var/run

	procd_open_instance
	procd_set_param command /usr/sbin/op-flowd -config /etc/config/op-flow daemon
	procd_set_param respawn 3600 5 5
	procd_set_param file /etc/config/op-flow
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

service_triggers() {
	procd_add_reload_trigger "op-flow"
}

reload_service() {
	stop
	start
}

